<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Shadow-Flow — Pentest Report | {{ meta.target }}</title>
  <style>
    :root {
      --bg:       #0d1117;
      --surface:  #161b22;
      --border:   #30363d;
      --accent:   #58a6ff;
      --red:      #f85149;
      --orange:   #e3702a;
      --yellow:   #d29922;
      --green:    #3fb950;
      --muted:    #8b949e;
      --text:     #e6edf3;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--text); font-family: 'Segoe UI', sans-serif; font-size: 14px; line-height: 1.6; }
    a { color: var(--accent); }

    /* ── Header ── */
    header { background: var(--surface); border-bottom: 1px solid var(--border); padding: 24px 40px; display: flex; justify-content: space-between; align-items: center; }
    .logo { font-size: 22px; font-weight: 700; letter-spacing: 2px; color: var(--accent); }
    .meta-pills { display: flex; gap: 12px; flex-wrap: wrap; }
    .pill { background: var(--bg); border: 1px solid var(--border); border-radius: 20px; padding: 4px 14px; font-size: 12px; color: var(--muted); }
    .pill span { color: var(--text); font-weight: 600; }

    /* ── Layout ── */
    main { max-width: 1200px; margin: 0 auto; padding: 32px 40px; }
    section { margin-bottom: 40px; }
    h2 { font-size: 18px; color: var(--accent); border-bottom: 1px solid var(--border); padding-bottom: 8px; margin-bottom: 20px; }
    h3 { font-size: 14px; color: var(--muted); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px; }

    /* ── Summary cards ── */
    .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 16px; }
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 20px; text-align: center; }
    .card .value { font-size: 32px; font-weight: 700; }
    .card .label { color: var(--muted); font-size: 12px; margin-top: 4px; }
    .card.crit .value { color: var(--red); }
    .card.high .value { color: var(--orange); }
    .card.med  .value { color: var(--yellow); }
    .card.low  .value { color: var(--green); }
    .card.info .value { color: var(--muted); }

    /* ── Severity badge ── */
    .badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 11px; font-weight: 700; text-transform: uppercase; }
    .badge.critical { background: rgba(248,81,73,0.15); color: var(--red); border: 1px solid var(--red); }
    .badge.high     { background: rgba(227,112,42,0.15); color: var(--orange); border: 1px solid var(--orange); }
    .badge.medium   { background: rgba(210,153,34,0.15); color: var(--yellow); border: 1px solid var(--yellow); }
    .badge.low      { background: rgba(63,185,80,0.15);  color: var(--green);  border: 1px solid var(--green); }
    .badge.info     { background: rgba(139,148,158,0.15);color: var(--muted);  border: 1px solid var(--border); }

    /* ── Tables ── */
    table { width: 100%; border-collapse: collapse; }
    th { background: var(--surface); color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; padding: 10px 14px; text-align: left; }
    td { padding: 10px 14px; border-top: 1px solid var(--border); vertical-align: top; }
    tr:hover td { background: rgba(88,166,255,0.04); }
    code { background: var(--bg); border: 1px solid var(--border); border-radius: 4px; padding: 2px 6px; font-size: 12px; font-family: 'Consolas', monospace; color: #79c0ff; }

    /* ── Attack chain ── */
    .chain { display: flex; gap: 0; flex-wrap: wrap; }
    .chain-step { background: var(--surface); border: 1px solid var(--border); padding: 8px 16px; font-size: 12px; position: relative; }
    .chain-step:not(:last-child)::after { content: '›'; position: absolute; right: -12px; top: 50%; transform: translateY(-50%); color: var(--accent); font-size: 18px; z-index: 1; }
    .chain-step.done { border-color: var(--green); color: var(--green); }

    /* ── Code blocks ── */
    pre { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 16px; overflow-x: auto; font-family: 'Consolas', monospace; font-size: 12px; color: #79c0ff; }

    /* ── Footer ── */
    footer { text-align: center; padding: 24px; color: var(--muted); font-size: 12px; border-top: 1px solid var(--border); }
  </style>
</head>
<body>

<header>
  <div class="logo">⚡ SHADOW-FLOW</div>
  <div class="meta-pills">
    <div class="pill">Target: <span>{{ meta.target }}</span></div>
    <div class="pill">Session: <span>{{ meta.session_id }}</span></div>
    <div class="pill">OS: <span>{{ target_profile.os_family | default('unknown') }}</span></div>
    <div class="pill">Type: <span>{{ target_profile.target_types | join(', ') }}</span></div>
    <div class="pill">Duration: <span>{{ meta.duration }}</span></div>
    <div class="pill">Generated: <span>{{ meta.generated }}</span></div>
  </div>
</header>

<main>

  <!-- ── Executive Summary ── -->
  <section>
    <h2>Executive Summary</h2>
    <div class="cards">
      <div class="card crit">
        <div class="value">{{ vuln_counts.critical }}</div>
        <div class="label">Critical</div>
      </div>
      <div class="card high">
        <div class="value">{{ vuln_counts.high }}</div>
        <div class="label">High</div>
      </div>
      <div class="card med">
        <div class="value">{{ vuln_counts.medium }}</div>
        <div class="label">Medium</div>
      </div>
      <div class="card low">
        <div class="value">{{ vuln_counts.low }}</div>
        <div class="label">Low</div>
      </div>
      <div class="card info">
        <div class="value">{{ open_port_count }}</div>
        <div class="label">Open Ports</div>
      </div>
      <div class="card info">
        <div class="value">{{ web_finding_count }}</div>
        <div class="label">Web Findings</div>
      </div>
    </div>
  </section>

  <!-- ── Attack Chain ── -->
  <section>
    <h2>Attack Chain</h2>
    <div class="chain">
      {% for step in attack_chain %}
      <div class="chain-step done">{{ step.phase | upper }}</div>
      {% endfor %}
    </div>
  </section>

  <!-- ── Open Ports ── -->
  <section>
    <h2>Open Ports</h2>
    {% if open_ports %}
    <table>
      <thead><tr><th>Port</th><th>Protocol</th><th>State</th><th>Service</th><th>Version</th></tr></thead>
      <tbody>
      {% for p in open_ports %}
        <tr>
          <td><code>{{ p.port }}</code></td>
          <td>{{ p.protocol }}</td>
          <td>{{ p.state }}</td>
          <td>{{ p.service }}</td>
          <td>{{ p.version }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p style="color:var(--muted)">No open ports discovered.</p>
    {% endif %}
  </section>

  <!-- ── Vulnerabilities ── -->
  <section>
    <h2>Vulnerabilities &amp; Exploit Candidates</h2>
    {% if vulnerabilities %}
    <table>
      <thead><tr><th>Severity</th><th>CVSS~</th><th>Port</th><th>Service</th><th>MSF Module</th><th>CVE Hints</th></tr></thead>
      <tbody>
      {% for v in vulnerabilities %}
        <tr>
          <td><span class="badge {{ v.severity }}">{{ v.severity }}</span></td>
          <td>{{ v.cvss_approx }}</td>
          <td><code>{{ v.port }}</code></td>
          <td>{{ v.service }} {{ v.version }}</td>
          <td><code>{{ v.msf_module }}</code></td>
          <td>{{ v.cve_hints | join(', ') }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p style="color:var(--muted)">No exploit candidates identified.</p>
    {% endif %}
  </section>

  <!-- ── NSE Script Findings ── -->
  {% if nse_vulnerabilities %}
  <section>
    <h2>NSE Script Vulnerabilities</h2>
    <table>
      <thead><tr><th>Port</th><th>Script</th><th>Output</th></tr></thead>
      <tbody>
      {% for f in nse_vulnerabilities %}
        <tr>
          <td><code>{{ f.port }}/{{ f.protocol }}</code></td>
          <td><code>{{ f.script }}</code></td>
          <td>{{ f.output[:300] }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  <!-- ── Web Findings (Nikto) ── -->
  {% if web_findings %}
  <section>
    <h2>Web Vulnerabilities (Nikto)</h2>
    <table>
      <thead><tr><th>Severity</th><th>URL</th><th>Description</th><th>OSVDB</th></tr></thead>
      <tbody>
      {% for f in web_findings %}
        <tr>
          <td><span class="badge {{ f.severity }}">{{ f.severity }}</span></td>
          <td><a href="{{ f.url }}" target="_blank">{{ f.url }}</a></td>
          <td>{{ f.description }}</td>
          <td>{{ f.osvdb }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  <!-- ── Persistence Simulation ── -->
  {% if persistence_audit %}
  <section>
    <h2>Persistence Techniques (Simulation)</h2>
    <table>
      <thead><tr><th>MITRE ID</th><th>Technique</th><th>Platform</th><th>Simulated Command</th><th>Detection</th></tr></thead>
      <tbody>
      {% for t in persistence_audit %}
        <tr>
          <td><a href="{{ t.mitre_url }}" target="_blank">{{ t.technique_id }}</a></td>
          <td>{{ t.name }}</td>
          <td>{{ t.platform }}</td>
          <td><code>{{ t.simulated_cmd }}</code></td>
          <td>{{ t.detection_rule }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  <!-- ── Remediation ── -->
  <section>
    <h2>Remediation Recommendations</h2>
    <table>
      <thead><tr><th>Finding</th><th>Recommendation</th><th>Priority</th></tr></thead>
      <tbody>
      {% for r in remediation %}
        <tr>
          <td>{{ r.finding }}</td>
          <td>{{ r.recommendation }}</td>
          <td><span class="badge {{ r.priority }}">{{ r.priority }}</span></td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </section>

</main>

<footer>
  Shadow-Flow v{{ meta.version }} &mdash; Automated Penetration Testing Toolkit &mdash;
  For authorized use only.
</footer>

</body>
</html>
