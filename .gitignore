# Shadow-Flow — .gitignore

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual environments ──────────────────────────────────
venv/
env/
.venv/
.env/
ENV/

# ── Tests ─────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
*.cover

# ── Generated output — DO NOT commit reports ─────────────
reports/
logs/
*.pcap
*.log

# ── IDE / Editor ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Secrets & Credentials ─────────────────────────────────
*.pem
*.key
*.p12
*.pfx
.env
secrets.yaml
secrets.json

# ── Metasploit ────────────────────────────────────────────
msf.rc
.msf4/
